# =========================================================================
# LastMinute AI — Workspace Environment Variables
# =========================================================================
# Copy relevant environment variables to backend/.env and frontend/.env
# as needed.

# Backend Config (backend/.env)
# -----------------------------
# Required: Google Gemini API Key for coaching, scheduling, and nudges
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional: Port for the backend API server (defaults to 3000)
PORT=3000

# Environment state
NODE_ENV=development
